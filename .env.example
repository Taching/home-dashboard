# Copy this file to .env on the Raspberry Pi. Never commit the real file.
TZ=Asia/Tokyo
SENSOR_POLL_INTERVAL_SECONDS=300
SENSOR_ENABLED=true
SENSOR_I2C_ADDRESS=68

# BroadLink RM4 Mini (IR only). Discover the values on the Pi, then learn
# light ON/OFF packets with `docker compose run --rm backend python -m app.tools.learn_broadlink`.
BROADLINK_HOST=
BROADLINK_MAC=
# Use the exact ID reported by app.tools.discover_broadlink. It differs by RM4 Mini revision.
BROADLINK_DEVICE_TYPE=
BROADLINK_CODES_PATH=/data/learned-codes/lights.json
SCREEN_ON_HOUR=10
SCREEN_OFF_HOUR=19

# Required in Phase 2 (voice). OpenAI receives only a short recording made
# after the local "Hey Chili" wake word is detected.
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
VOICE_COMMAND_MODEL=gpt-5-mini
PI_VOLUME_CARD=0
PI_VOLUME_CONTROL=PCM
PI_VOLUME_STEP_PERCENT=10
VOICE_AUDIO_DEVICE=plughw:2,0
VOICE_WAKEWORD_MODEL=/models/hey_chili.tflite
VOICE_WAKEWORD_LABEL=Hey Chili
VOICE_WAKEWORD_THRESHOLD=0.4
VOICE_WAKEWORD_REARM_SECONDS=0.5
VOICE_COOLDOWN_SECONDS=1.5
VOICE_POST_WAKE_SKIP_SECONDS=0.3
VOICE_COMMAND_MIN_SECONDS=1.0
VOICE_COMMAND_SILENCE_SECONDS=0.8
VOICE_COMMAND_MAX_SECONDS=5
VOICE_SILENCE_RMS_THRESHOLD=380

# Spotify now-playing (server-side OAuth)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/api/v1/spotify/callback

# Apple Calendar bridge. Use a long random value; it authenticates the Mac helper.
APPLE_CALENDAR_BRIDGE_TOKEN=
CALENDAR_BRIDGE_BIND_ADDRESS=127.0.0.1
FRONTEND_BIND_ADDRESS=127.0.0.1

# Notion tasks. Share the task database/data source with your Notion integration.
NOTION_TOKEN=
NOTION_DATA_SOURCE_ID=
NOTION_DATABASE_ID=
NOTION_TITLE_PROPERTY=Name
NOTION_DUE_PROPERTY=Due Date
NOTION_DONE_PROPERTY=Done
NOTION_STATUS_PROPERTY=Status
NOTION_DONE_STATUSES=Done,Complete,Completed

# OpenClaw shared main session. The token is backend-only; never expose it to React.
OPENCLAW_GATEWAY_WS_URL=ws://host.docker.internal:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_SESSION_KEY=agent:main:main
